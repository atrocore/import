{
  "fields": {
    "name": {
      "type": "varchar",
      "required": true,
      "trim": true
    },
    "code": {
      "type": "varchar",
      "unique": true
    },
    "description": {
      "type": "text"
    },
    "maxPerJob": {
      "type": "int",
      "required": false,
      "min": 0
    },
    "executeAs": {
      "type": "enum",
      "prohibitedEmptyValue": true,
      "default": "system",

      "options": [
        "system",
        "sameUser"
      ],
      "tooltip": true
    },
    "configuratorItems": {
      "type": "linkMultiple",
      "layoutDetailDisabled": true,
      "layoutMassUpdateDisabled": true,
      "filterDisabled": true,
      "noLoad": true
    },
    "isActive": {
      "type": "bool"
    },
    "repeatProcessing": {
      "type": "enum",
      "required": true,
      "prohibitedEmptyValue": true,
      "options": [
        "mistake",
        "repeat",
        "skip"
      ],
      "default": "mistake",
      "tooltip": true
    },
    "type": {
      "type": "enum",
      "required": true,
      "prohibitedEmptyValue": true,
      "options": [
        "simple"
      ],
      "default": "simple"
    },
    "processingType": {
      "type": "varchar",
      "view": "import:views/import-feed/fields/processing-type",
      "required": true,
      "default": "configurator"
    },
    "data": {
      "type": "jsonObject",
      "filterDisabled": true,
      "layoutListDisabled": true
    },
    "importFile": {
      "type": "file",
      "notStorable": true,
      "layoutDetailDisabled": true,
      "layoutListDisabled": true,
      "layoutMassUpdateDisabled": true,
      "filterDisabled": true,
      "exportDisabled": true,
      "importDisabled": true,
      "textFilterDisabled": true,
      "emHidden": true
    },
    "file": {
      "type": "file",
      "required": false,
      "filterDisabled": true,
      "tooltip": true,
      "view": "import:views/import-feed/fields/file"
    },
    "sheet": {
      "type": "int",
      "view": "import:views/import-feed/fields/sheet",
      "required": false,
      "prohibitedEmptyValue": true,
      "default": 0
    },
    "sheetOptions": {
      "type": "array",
      "notStorable": true,
      "dataField": true,
      "required": false,
      "layoutDetailDisabled": true,
      "layoutListDisabled": true,
      "layoutMassUpdateDisabled": true,
      "filterDisabled": true,
      "exportDisabled": true,
      "importDisabled": true,
      "textFilterDisabled": true,
      "emHidden": true
    },
    "fileFieldDelimiter": {
      "type": "enum",
      "notStorable": true,
      "dataField": true,
      "filterDisabled": true,
      "required": false,
      "prohibitedEmptyValue": true,
      "options": [
        ",",
        ";",
        "\\t"
      ],
      "default": ";"
    },
    "format": {
      "type": "enum",
      "view": "import:views/import-feed/fields/format",
      "required": false,
      "notStorable": true,
      "dataField": true,
      "filterDisabled": true,
      "prohibitedEmptyValue": true,
      "options": [
        "CSV",
        "Excel",
        "JSON",
        "XML"
      ],
      "default": "CSV"
    },
    "fileTextQualifier": {
      "type": "enum",
      "notStorable": true,
      "dataField": true,
      "filterDisabled": true,
      "required": false,
      "prohibitedEmptyValue": true,
      "options": [
        "doubleQuote",
        "singleQuote"
      ],
      "default": "doubleQuote"
    },
    "fileDataAction": {
      "type": "enum",
      "required": false,
      "prohibitedEmptyValue": true,
      "options": [
        "create",
        "update",
        "delete_found",
        "delete_not_found",
        "create_update",
        "create_delete",
        "update_delete",
        "create_update_delete"
      ],
      "default": "create"
    },
    "isFileHeaderRow": {
      "type": "bool",
      "notStorable": true,
      "dataField": true,
      "filterDisabled": true,
      "default": true
    },
    "decimalMark": {
      "type": "varchar",
      "notStorable": true,
      "dataField": true,
      "filterDisabled": true,
      "required": true,
      "default": ","
    },
    "thousandSeparator": {
      "type": "varchar",
      "notStorable": true,
      "dataField": true,
      "filterDisabled": true,
      "required": false
    },
    "adapter": {
      "type": "enum",
      "options": [
        ""
      ],
      "notStorable": true,
      "dataField": true,
      "prohibitedEmptyValue": false,
      "filterDisabled": true,
      "view": "import:views/import-feed/fields/adapter"
    },
    "phpCode": {
      "type": "wysiwyg",
      "readOnly": true,
      "notStorable": true,
      "layoutDetailDisabled": true,
      "layoutListDisabled": true,
      "massUpdateDisabled": true,
      "filterDisabled": true,
      "importDisabled": true,
      "textFilterDisabled": true
    },
    "createdAt": {
      "type": "datetime",
      "readOnly": true
    },
    "modifiedAt": {
      "type": "datetime",
      "readOnly": true
    },
    "createdBy": {
      "type": "link",
      "readOnly": true,
      "view": "views/fields/user"
    },
    "modifiedBy": {
      "type": "link",
      "readOnly": true,
      "view": "views/fields/user"
    },
    "ownerUser": {
      "type": "link",
      "required": false,
      "view": "views/fields/owner-user"
    },
    "assignedUser": {
      "type": "link",
      "required": false,
      "view": "views/fields/assigned-user"
    },
    "teams": {
      "type": "linkMultiple",
      "view": "views/fields/teams"
    },
    "importJobs": {
      "type": "linkMultiple",
      "layoutDetailDisabled": true,
      "layoutMassUpdateDisabled": true,
      "filterDisabled": true,
      "noLoad": true,
      "importDisabled": true
    },
    "entity": {
      "type": "enum",
      "notStorable": true,
      "dataField": true,
      "filterDisabled": true,
      "view": "import:views/import-feed/fields/entity",
      "required": true,
      "prohibitedEmptyValue": true,
      "default": "Product"
    },
    "rootNode": {
      "type": "varchar",
      "required": false,
      "notStorable": true,
      "dataField": true,
      "filterDisabled": true
    },
    "excludedNodes": {
      "type": "array",
      "required": false,
      "notStorable": true,
      "dataField": true,
      "filterDisabled": true
    },
    "keptStringNodes": {
      "type": "array",
      "required": false,
      "notStorable": true,
      "dataField": true,
      "filterDisabled": true,
      "tooltip": true
    },
    "delimiter": {
      "type": "varchar",
      "notStorable": true,
      "dataField": true,
      "filterDisabled": true,
      "required": true,
      "default": "~"
    },
    "fieldDelimiterForRelation": {
      "type": "varchar",
      "notStorable": true,
      "dataField": true,
      "filterDisabled": true,
      "required": true,
      "default": "|"
    },
    "emptyValue": {
      "type": "varchar",
      "notStorable": true,
      "dataField": true,
      "filterDisabled": true,
      "required": false,
      "default": "",
      "tooltip": true
    },
    "nullValue": {
      "type": "varchar",
      "notStorable": true,
      "dataField": true,
      "filterDisabled": true,
      "required": false,
      "default": "Null",
      "tooltip": true
    },
    "markForNoRelation": {
      "type": "varchar",
      "notStorable": true,
      "dataField": true,
      "filterDisabled": true,
      "required": false,
      "default": "Null",
      "tooltip": true
    },
    "markForUnlinkedAttribute": {
      "type": "varchar",
      "notStorable": true,
      "dataField": true,
      "filterDisabled": true,
      "required": false,
      "default": "N/A",
      "tooltip": true
    },
    "skipValue": {
      "type": "varchar",
      "notStorable": true,
      "dataField": true,
      "filterDisabled": true,
      "required": false,
      "default": "Skip",
      "tooltip": true
    },
    "sourceFields": {
      "type": "array",
      "view": "import:views/import-feed/fields/source-fields"
    },
    "connection": {
      "type": "link",
      "view": "import:views/import-feed/fields/connection"
    },
    "lastTime": {
      "type": "datetime",
      "readOnly": true,
      "notStorable": true,
      "filterDisabled": true
    },
    "feedPayload": {
      "type": "text",
      "view": "views/fields/script",
      "language": "json",
      "notStorable": true,
      "dataField": true
    }
  },
  "links": {
    "configuratorItems": {
      "type": "hasMany",
      "foreign": "importFeed",
      "entity": "ImportConfiguratorItem",
      "audited": false
    },
    "createdBy": {
      "type": "belongsTo",
      "entity": "User"
    },
    "modifiedBy": {
      "type": "belongsTo",
      "entity": "User"
    },
    "ownerUser": {
      "type": "belongsTo",
      "entity": "User"
    },
    "assignedUser": {
      "type": "belongsTo",
      "entity": "User"
    },
    "teams": {
      "type": "hasMany",
      "entity": "Team",
      "relationName": "EntityTeam",
      "layoutRelationshipsDisabled": true
    },
    "importJobs": {
      "type": "hasMany",
      "foreign": "importFeed",
      "entity": "ImportJob"
    },
    "connection": {
      "type": "belongsTo",
      "entity": "Connection"
    }
  },
  "collection": {
    "sortBy": "createdAt",
    "asc": false
  },
  "indexes": {
    "name": {
      "columns": [
        "name",
        "deleted"
      ]
    },
    "ownerUser": {
      "columns": [
        "ownerUserId",
        "deleted"
      ]
    },
    "assignedUser": {
      "columns": [
        "assignedUserId",
        "deleted"
      ]
    }
  }
}
