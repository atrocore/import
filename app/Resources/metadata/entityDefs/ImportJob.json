{
  "fields": {
    "name": {
      "type": "varchar",
      "required": true,
      "trim": true,
      "readOnly": true
    },
    "trial": {
      "type": "int",
      "default": 0,
      "readOnly": true
    },
    "importFeed": {
      "type": "link",
      "readOnly": true
    },
    "queueItem": {
      "type": "link",
      "readOnly": true
    },
    "sortOrder": {
      "type": "float",
      "readOnly": true
    },
    "entityName": {
      "type": "varchar",
      "readOnly": true,
      "layoutDetailDisabled": true,
      "layoutListDisabled": true,
      "filterDisabled": true
    },
    "state": {
      "type": "enum",
      "required": true,
      "fontSize": 1,
      "optionsIds": [
        "Pending",
        "Running",
        "Success",
        "Failed",
        "Canceled"
      ],
      "options": [
        "Pending",
        "Running",
        "Success",
        "Failed",
        "Canceled"
      ],
      "optionColors": [
        "b5e8ff",
        "fff078",
        "8fff87",
        "ff6262",
        "eeeeee"
      ],
      "default": "Pending",
      "readOnly": true,
      "view": "import:views/import-job/fields/state-message"
    },
    "message": {
      "type": "text",
      "readOnly": true,
      "layoutDetailDisabled": false,
      "layoutListDisabled": false,
      "filterDisabled": false
    },
    "processingType": {
      "type": "varchar",
      "readOnly": true,
      "notStorable": true,
      "layoutDetailDisabled": true,
      "layoutListDisabled": true,
      "massUpdateDisabled": true,
      "filterDisabled": true,
      "importDisabled": true,
      "textFilterDisabled": true
    },
    "start": {
      "notNull": false,
      "type": "datetime",
      "readOnly": true
    },
    "end": {
      "notNull": false,
      "type": "datetime",
      "readOnly": true
    },
    "createdCount": {
      "type": "int",
      "readOnly": true,
      "view": "import:views/import-job/fields/created-count"
    },
    "updatedCount": {
      "type": "int",
      "readOnly": true,
      "view": "import:views/import-job/fields/updated-count"
    },
    "deletedCount": {
      "type": "int",
      "readOnly": true,
      "view": "import:views/import-job/fields/records-counter-with-link"
    },
    "skippedCount": {
      "type": "int",
      "readOnly": true,
      "view": "import:views/import-job/fields/records-counter-with-link",
      "disableFormatting": true
    },
    "errorsCount": {
      "type": "int",
      "readOnly": true,
      "view": "import:views/import-job/fields/records-counter-with-link",
      "disableFormatting": true
    },
    "attachment": {
      "type": "file",
      "readOnly": true
    },
    "convertedFile": {
      "type": "file",
      "view": "import:views/import-job/fields/generated-file",
      "readOnly": true
    },
    "importJobLogs": {
      "type": "linkMultiple",
      "layoutDetailDisabled": true,
      "massUpdateDisabled": true,
      "noLoad": true,
      "importDisabled": true
    },
    "parent": {
      "type": "link"
    },
    "children": {
      "type": "linkMultiple",
      "noLoad": true
    },
    "payload": {
      "type": "jsonObject",
      "notStorable": true,
      "layoutDetailDisabled": true,
      "layoutListDisabled": true,
      "massUpdateDisabled": true,
      "filterDisabled": true,
      "exportDisabled": true,
      "importDisabled": true,
      "textFilterDisabled": true,
      "emHidden": true
    },
    "files": {
      "type": "linkMultiple",
      "layoutDetailDisabled": true,
      "massUpdateDisabled": true,
      "noLoad": true
    },
    "createdAt": {
      "type": "datetime",
      "readOnly": true
    },
    "modifiedAt": {
      "type": "datetime",
      "readOnly": true
    },
    "createdBy": {
      "type": "link",
      "readOnly": true,
      "view": "views/fields/user"
    },
    "modifiedBy": {
      "type": "link",
      "readOnly": true,
      "view": "views/fields/user"
    }
  },
  "links": {
    "importFeed": {
      "type": "belongsTo",
      "foreign": "importJobs",
      "entity": "ImportFeed"
    },
    "parent": {
      "type": "belongsTo",
      "foreign": "children",
      "entity": "ImportJob"
    },
    "children": {
      "type": "hasMany",
      "foreign": "parent",
      "entity": "ImportJob"
    },
    "queueItem": {
      "type": "belongsTo",
      "entity": "Job"
    },
    "importJobLogs": {
      "type": "hasMany",
      "foreign": "importJob",
      "entity": "ImportJobLog"
    },
    "files": {
      "type": "hasMany",
      "relationName": "importJobFile",
      "foreign": "importJobs",
      "entity": "File"
    },
    "createdBy": {
      "type": "belongsTo",
      "entity": "User"
    },
    "modifiedBy": {
      "type": "belongsTo",
      "entity": "User"
    }
  },
  "collection": {
    "sortBy": "sortOrder",
    "asc": false
  },
  "indexes": {
    "name": {
      "columns": [
        "name",
        "deleted"
      ]
    },
    "entityName": {
      "columns": [
        "entityName",
        "deleted"
      ]
    },
    "state": {
      "columns": [
        "state",
        "deleted"
      ]
    },
    "start": {
      "columns": [
        "start",
        "deleted"
      ]
    },
    "end": {
      "columns": [
        "end",
        "deleted"
      ]
    },
    "createdAt": {
      "columns": [
        "createdAt",
        "deleted"
      ]
    },
    "modifiedAt": {
      "columns": [
        "modifiedAt",
        "deleted"
      ]
    }
  }
}