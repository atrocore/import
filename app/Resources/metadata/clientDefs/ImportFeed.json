{
  "controller": "controllers/record",
  "boolFilterList": [
    "onlyMy",
    "onlyImportFailed24Hours",
    "onlyImportFailed7Days",
    "onlyImportFailed28Days"
  ],
  "iconClass": "download-simple",
  "views": {
    "detail": "import:views/import-feed/detail"
  },
  "recordViews": {
    "detail": "import:views/import-feed/record/detail"
  },
  "relationshipPanels": {
    "configuratorItems": {
      "select": false,
      "hideShowFullList": true,
      "canClose": false,
      "dragDrop": {
        "isActive": true,
        "maxSize": 20,
        "sortField": "sortOrder"
      },
      "rowActionsView": "views/record/row-actions/edit-and-remove",
      "view": "import:views/import-feed/record/panels/configurator-items"
    },
    "importJobs": {
      "create": false,
      "select": false,
      "canClose": false,
      "where": [
        {
          "type": "isNull",
          "attribute": "parentId"
        }
      ],
      "rowActionsView": "import:views/import-feed/record/row-actions/import-jobs",
      "view": "import:views/import-feed/record/panels/import-jobs"
    }
  },
  "dynamicLogic": {
    "fields": {
      "maxPerJob": {
        "visible": {
          "conditionGroup": [
            {
              "type": "or",
              "value": [
                {
                  "type": "in",
                  "attribute": "format",
                  "value": [
                    "CSV",
                    "Excel"
                  ]
                },
                {
                  "type": "isTrue",
                  "attribute": "mergeResponses"
                }
              ]
            }
          ]
        }
      },
      "type": {
        "readOnly": {
          "conditionGroup": [
            {
              "type": "isNotEmpty",
              "attribute": "id"
            }
          ]
        }
      },
      "isFileHeaderRow": {
        "visible": {
          "conditionGroup": [
            {
              "type": "in",
              "attribute": "format",
              "value": [
                "CSV",
                "Excel"
              ]
            }
          ]
        }
      },
      "delimiter": {
        "visible": {
          "conditionGroup": [
            {
              "type": "equals",
              "attribute": "processingType",
              "value": "configurator"
            }
          ]
        }
      },
      "fieldDelimiterForRelation": {
        "visible": {
          "conditionGroup": [
            {
              "type": "equals",
              "attribute": "processingType",
              "value": "configurator"
            }
          ]
        }
      },
      "thousandSeparator": {
        "visible": {
          "conditionGroup": [
            {
              "type": "equals",
              "attribute": "processingType",
              "value": "configurator"
            }
          ]
        }
      },
      "emptyValue": {
        "visible": {
          "conditionGroup": [
            {
              "type": "equals",
              "attribute": "processingType",
              "value": "configurator"
            }
          ]
        }
      },
      "nullValue": {
        "visible": {
          "conditionGroup": [
            {
              "type": "equals",
              "attribute": "processingType",
              "value": "configurator"
            }
          ]
        }
      },
      "markForNoRelation": {
        "visible": {
          "conditionGroup": [
            {
              "type": "equals",
              "attribute": "processingType",
              "value": "configurator"
            }
          ]
        }
      },
      "markForUnlinkedAttribute": {
        "visible": {
          "conditionGroup": [
            {
              "type": "equals",
              "attribute": "processingType",
              "value": "configurator"
            }
          ]
        }
      },
      "skipValue": {
        "visible": {
          "conditionGroup": [
            {
              "type": "equals",
              "attribute": "processingType",
              "value": "configurator"
            }
          ]
        }
      },
      "rootNode": {
        "visible": {
          "conditionGroup": [
            {
              "type": "in",
              "attribute": "format",
              "value": [
                "JSON",
                "XML"
              ]
            },
            {
              "type": "equals",
              "attribute": "processingType",
              "value": "configurator"
            }
          ]
        }
      },
      "excludedNodes": {
        "visible": {
          "conditionGroup": [
            {
              "type": "in",
              "attribute": "format",
              "value": [
                "JSON",
                "XML"
              ]
            },
            {
              "type": "equals",
              "attribute": "processingType",
              "value": "configurator"
            }
          ]
        }
      },
      "keptStringNodes": {
        "visible": {
          "conditionGroup": [
            {
              "type": "in",
              "attribute": "format",
              "value": [
                "JSON",
                "XML"
              ]
            },
            {
              "type": "equals",
              "attribute": "processingType",
              "value": "configurator"
            }
          ]
        }
      },
      "decimalMark": {
        "visible": {
          "conditionGroup": [
            {
              "type": "equals",
              "attribute": "format",
              "value": "CSV"
            },
            {
              "type": "equals",
              "attribute": "processingType",
              "value": "configurator"
            }
          ]
        },
        "required": {
          "conditionGroup": [
            {
              "type": "equals",
              "attribute": "format",
              "value": "CSV"
            }
          ]
        }
      },
      "fileFieldDelimiter": {
        "visible": {
          "conditionGroup": [
            {
              "type": "equals",
              "attribute": "format",
              "value": "CSV"
            }
          ]
        },
        "required": {
          "conditionGroup": [
            {
              "type": "equals",
              "attribute": "format",
              "value": "CSV"
            }
          ]
        }
      },
      "fileTextQualifier": {
        "visible": {
          "conditionGroup": [
            {
              "type": "equals",
              "attribute": "format",
              "value": "CSV"
            }
          ]
        },
        "required": {
          "conditionGroup": [
            {
              "type": "equals",
              "attribute": "format",
              "value": "CSV"
            }
          ]
        }
      },
      "feedPayload": {
        "visible": {
          "conditionGroup": [
            {
              "type": "notEquals",
              "attribute": "processingType",
              "value": "configurator"
            }
          ]
        }
      }
    }
  }
}
